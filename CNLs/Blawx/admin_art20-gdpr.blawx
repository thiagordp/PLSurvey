    scasp_encoding: "blawx_attribute(data,public_interest,controller).\nblawx_attribute_nlg(public_interest,ov,\"the
      data\",\"is processed by\",\"for public interest\").\n:- dynamic public_interest/2.\n#pred
      public_interest(X,Y) :: 'the data @(X) is processed by @(Y) for public interest'.\n#pred
      holds(user,public_interest,X,Y) :: 'it is provided as a fact that the data @(X)
      is processed by @(Y) for public interest'.\n#pred holds(user,-public_interest,X,Y)
      :: 'it is provided as a fact that it is not the case that the data @(X) is processed
      by @(Y) for public interest'.\n#pred holds(Z,public_interest,X,Y) :: 'the conclusion
      in @(Z) that the data @(X) is processed by @(Y) for public interest holds'.\n#pred
      holds(Z,-public_interest,X,Y) :: 'the conclusion in @(Z) that it is not the
      case that the data @(X) is processed by @(Y) for public interest holds'.\n#pred
      according_to(Z,public_interest,X,Y) :: 'according to @(Z), the data @(X) is
      processed by @(Y) for public interest'.\n#pred according_to(Z,-public_interest,X,Y)
      :: 'according to @(Z), it is not the case that the data @(X) is processed by
      @(Y) for public interest'.\n#pred blawx_defeated(Z,public_interest,X,Y) :: 'the
      conclusion in @(Z) that the data @(X) is processed by @(Y) for public interest
      is defeated'.\n#pred blawx_defeated(Z,-public_interest,X,Y) :: 'the conclusion
      in @(Z) that the data @(X) is processed by @(Y) for public interest is defeated'.\n#pred
      blawx_initially(public_interest(X,Y)) :: 'that the data @(X) is processed by
      @(Y) for public interest holds initially'.\n#pred blawx_initially(-public_interest(X,Y))
      :: 'that it is not the case that the data @(X) is processed by @(Y) for public
      interest holds initially'.\n#pred blawx_ultimately(public_interest(X,Y)) ::
      'that the data @(X) is processed by @(Y) for public interest holds ultimately'.\n#pred
      blawx_ultimately(-public_interest(X,Y)) :: 'that it is not the case that the
      data @(X) is processed by @(Y) for public interest holds ultimately'.\n#pred
      blawx_as_of(public_interest(X,Y),T) :: 'that the data @(X) is processed by @(Y)
      for public interest holds at @(T)'.\n#pred blawx_as_of(-public_interest(X,Y),T)
      :: 'that it is not the case that the data @(X) is processed by @(Y) for public
      interest holds at @(T)'.\n#pred blawx_during(T1,public_interest(X,Y),T2) ::
      'that the data @(X) is processed by @(Y) for public interest held between @(T1)
      and @(T2)'.\n#pred blawx_during(T1,-public_interest(X,Y),T2) :: 'that it is
      not the case that the data @(X) is processed by @(Y) for public interest held
      between @(T1) and @(T2)'.\n#pred blawx_becomes(public_interest(X,Y),T) :: 'that
      the data @(X) is processed by @(Y) for public interest became true at @(T)'.\n#pred
      blawx_becomes(-public_interest(X,Y),T) :: 'that it is not the case that the
      data @(X) is processed by @(Y) for public interest became true at @(T)'.\n#pred
      blawx_not_interrupted(Start,public_interest(X,Y),End) :: 'the data @(X) is processed
      by @(Y) for public interest remained the case between @(Start) and @(End)'.\n#pred
      blawx_not_interrupted(Start,-public_interest(X,Y),End) :: 'it is not the case
      that the data @(X) is processed by @(Y) for public interest remained the case
      between @(Start) and @(End)'.\nblawx_not_interrupted(datetime(Start),public_interest(X,Y),datetime(End))
      :- Start \\= bot, End \\= eot, findall(Time,blawx_becomes(-public_interest(X,Y),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).\nblawx_not_interrupted(datetime(Start),-public_interest(X,Y),datetime(End))
      :- Start \\= bot, End \\= eot, findall(Time,blawx_becomes(public_interest(X,Y),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).\nblawx_not_interrupted(datetime(bot),public_interest(X,Y),datetime(End))
      :- End \\= eot, findall(Time,blawx_becomes(-public_interest(X,Y),datetime(Time)),Times),blawx_list_not_before(Times,End).\nblawx_not_interrupted(datetime(bot),-public_interest(X,Y),datetime(End))
      :- End \\= eot, findall(Time,blawx_becomes(public_interest(X,Y),datetime(Time)),Times),blawx_list_not_before(Times,End).\nblawx_not_interrupted(datetime(Start),public_interest(X,Y),datetime(eot))
      :- Start \\= bot, findall(Time,blawx_becomes(-public_interest(X,Y),datetime(Time)),Times),blawx_list_not_after(Times,Start).\nblawx_not_interrupted(datetime(Start),-public_interest(X,Y),datetime(eot))
      :- Start \\= bot, findall(Time,blawx_becomes(public_interest(X,Y),datetime(Time)),Times),blawx_list_not_after(Times,Start).\nblawx_not_interrupted(datetime(bot),public_interest(X,Y),datetime(eot))
      :- blawx_initially(public_interest(X,Y)), blawx_ultimately(public_interest(X,Y)),
      findall(Time,blawx_becomes(-public_interest(X,Y),datetime(Time)),[]).\nblawx_not_interrupted(datetime(bot),-public_interest(X,Y),datetime(eot))
      :- blawx_initially(-public_interest(X,Y)), blawx_ultimately(-public_interest(X,Y)),
      findall(Time,blawx_becomes(public_interest(X,Y),datetime(Time)),[]).\nblawx_as_of(public_interest(X,Y),datetime(Time))
      :- blawx_initially(public_interest(X,Y)), BeforeT #< Time,blawx_not_interrupted(datetime(bot),public_interest(X,Y),datetime(BeforeT)).\nblawx_as_of(public_interest(X,Y),datetime(Time))
      :- blawx_becomes(public_interest(X,Y),datetime(BeforeT)),BeforeT #< Time,blawx_not_interrupted(datetime(BeforeT),public_interest(X,Y),datetime(Time)).\nblawx_as_of(-public_interest(X,Y),datetime(Time))
      :- blawx_initially(-public_interest(X,Y)), BeforeT #< Time,blawx_not_interrupted(datetime(bot),-public_interest(X,Y),datetime(BeforeT)).\nblawx_as_of(-public_interest(X,Y),datetime(Time))
      :- blawx_becomes(-public_interest(X,Y),datetime(BeforeT)),BeforeT #< Time,blawx_not_interrupted(datetime(BeforeT),-public_interest(X,Y),datetime(Time)).\nblawx_during(datetime(Start),public_interest(X,Y),datetime(End))
      :- blawx_becomes(public_interest(X,Y),datetime(Start)), blawx_becomes(-public_interest(X,Y),datetime(End)),
      Start #< End, blawx_not_interrupted(datetime(Start),public_interest(X,Y),datetime(End)).\nblawx_during(datetime(bot),public_interest(X,Y),datetime(End))
      :- blawx_initially(public_interest(X,Y)), blawx_becomes(-public_interest(X,Y),datetime(End)),
      blawx_not_interrupted(datetime(bot),public_interest(X,Y),datetime(End)).\nblawx_during(datetime(Start),public_interest(X,Y),datetime(eot))
      :- blawx_ultimately(public_interest(X,Y)), blawx_becomes(-public_interest(X,Y),datetime(Start)),
      blawx_not_interrupted(datetime(Start),public_interest(X,Y),datetime(eot)).\nblawx_during(datetime(bot),public_interest(X,Y),datetime(eot))
      :- blawx_initially(public_interest(X,Y)), blawx_ultimately(public_interest(X,Y)),
      blawx_becomes(-public_interest(X,Y),datetime(Start)), blawx_not_interrupted(datetime(bot),public_interest(X,Y),datetime(eot)).\nblawx_during(datetime(Start),-public_interest(X,Y),datetime(End))
      :- blawx_becomes(-public_interest(X,Y),datetime(Start)), blawx_becomes(public_interest(X,Y),datetime(End)),
      Start #< End, blawx_not_interrupted(datetime(Start),-public_interest(X,Y),datetime(End)).\nblawx_during(datetime(bot),-public_interest(X,Y),datetime(End))
      :- blawx_initially(-public_interest(X,Y)), blawx_becomes(public_interest(X,Y),datetime(End)),
      blawx_not_interrupted(datetime(bot),-public_interest(X,Y),datetime(End)).\nblawx_during(datetime(Start),-public_interest(X,Y),datetime(eot))
      :- blawx_ultimately(-public_interest(X,Y)), blawx_becomes(public_interest(X,Y),datetime(Start)),
      blawx_not_interrupted(datetime(Start),-public_interest(X,Y),datetime(eot)).\nblawx_during(datetime(bot),-public_interest(X,Y),datetime(eot))
      :- blawx_initially(-public_interest(X,Y)), blawx_ultimately(-public_interest(X,Y)),
      blawx_becomes(-public_interest(X,Y),datetime(Start)), blawx_not_interrupted(datetime(bot),-public_interest(X,Y),datetime(eot)).\nblawx_attribute(data,official_authority,controller).\nblawx_attribute_nlg(official_authority,ov,\"the
      data\",\"is processed by\",\" in the excercise of official authority\").\n:-
      dynamic official_authority/2.\n#pred official_authority(X,Y) :: 'the data @(X)
      is processed by @(Y)  in the excercise of official authority'.\n#pred holds(user,official_authority,X,Y)
      :: 'it is provided as a fact that the data @(X) is processed by @(Y)  in the
      excercise of official authority'.\n#pred holds(user,-official_authority,X,Y)
      :: 'it is provided as a fact that it is not the case that the data @(X) is processed
      by @(Y)  in the excercise of official authority'.\n#pred holds(Z,official_authority,X,Y)
      :: 'the conclusion in @(Z) that the data @(X) is processed by @(Y)  in the excercise
      of official authority holds'.\n#pred holds(Z,-official_authority,X,Y) :: 'the
      conclusion in @(Z) that it is not the case that the data @(X) is processed by
      @(Y)  in the excercise of official authority holds'.\n#pred according_to(Z,official_authority,X,Y)
      :: 'according to @(Z), the data @(X) is processed by @(Y)  in the excercise
      of official authority'.\n#pred according_to(Z,-official_authority,X,Y) :: 'according
      to @(Z), it is not the case that the data @(X) is processed by @(Y)  in the
      excercise of official authority'.\n#pred blawx_defeated(Z,official_authority,X,Y)
      :: 'the conclusion in @(Z) that the data @(X) is processed by @(Y)  in the excercise
      of official authority is defeated'.\n#pred blawx_defeated(Z,-official_authority,X,Y)
      :: 'the conclusion in @(Z) that the data @(X) is processed by @(Y)  in the excercise
      of official authority is defeated'.\n#pred blawx_initially(official_authority(X,Y))
      :: 'that the data @(X) is processed by @(Y)  in the excercise of official authority
      holds initially'.\n#pred blawx_initially(-official_authority(X,Y)) :: 'that
      it is not the case that the data @(X) is processed by @(Y)  in the excercise
      of official authority holds initially'.\n#pred blawx_ultimately(official_authority(X,Y))
      :: 'that the data @(X) is processed by @(Y)  in the excercise of official authority
      holds ultimately'.\n#pred blawx_ultimately(-official_authority(X,Y)) :: 'that
      it is not the case that the data @(X) is processed by @(Y)  in the excercise
      of official authority holds ultimately'.\n#pred blawx_as_of(official_authority(X,Y),T)
      :: 'that the data @(X) is processed by @(Y)  in the excercise of official authority
      holds at @(T)'.\n#pred blawx_as_of(-official_authority(X,Y),T) :: 'that it is
      not the case that the data @(X) is processed by @(Y)  in the excercise of official
      authority holds at @(T)'.\n#pred blawx_during(T1,official_authority(X,Y),T2)
      :: 'that the data @(X) is processed by @(Y)  in the excercise of official authority
      held between @(T1) and @(T2)'.\n#pred blawx_during(T1,-official_authority(X,Y),T2)
      :: 'that it is not the case that the data @(X) is processed by @(Y)  in the
      excercise of official authority held between @(T1) and @(T2)'.\n#pred blawx_becomes(official_authority(X,Y),T)
      :: 'that the data @(X) is processed by @(Y)  in the excercise of official authority
      became true at @(T)'.\n#pred blawx_becomes(-official_authority(X,Y),T) :: 'that
      it is not the case that the data @(X) is processed by @(Y)  in the excercise
      of official authority became true at @(T)'.\n#pred blawx_not_interrupted(Start,official_authority(X,Y),End)
      :: 'the data @(X) is processed by @(Y)  in the excercise of official authority
      remained the case between @(Start) and @(End)'.\n#pred blawx_not_interrupted(Start,-official_authority(X,Y),End)
      :: 'it is not the case that the data @(X) is processed by @(Y)  in the excercise
      of official authority remained the case between @(Start) and @(End)'.\nblawx_not_interrupted(datetime(Start),official_authority(X,Y),datetime(End))
      :- Start \\= bot, End \\= eot, findall(Time,blawx_becomes(-official_authority(X,Y),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).\nblawx_not_interrupted(datetime(Start),-official_authority(X,Y),datetime(End))
      :- Start \\= bot, End \\= eot, findall(Time,blawx_becomes(official_authority(X,Y),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).\nblawx_not_interrupted(datetime(bot),official_authority(X,Y),datetime(End))
      :- End \\= eot, findall(Time,blawx_becomes(-official_authority(X,Y),datetime(Time)),Times),blawx_list_not_before(Times,End).\nblawx_not_interrupted(datetime(bot),-official_authority(X,Y),datetime(End))
      :- End \\= eot, findall(Time,blawx_becomes(official_authority(X,Y),datetime(Time)),Times),blawx_list_not_before(Times,End).\nblawx_not_interrupted(datetime(Start),official_authority(X,Y),datetime(eot))
      :- Start \\= bot, findall(Time,blawx_becomes(-official_authority(X,Y),datetime(Time)),Times),blawx_list_not_after(Times,Start).\nblawx_not_interrupted(datetime(Start),-official_authority(X,Y),datetime(eot))
      :- Start \\= bot, findall(Time,blawx_becomes(official_authority(X,Y),datetime(Time)),Times),blawx_list_not_after(Times,Start).\nblawx_not_interrupted(datetime(bot),official_authority(X,Y),datetime(eot))
      :- blawx_initially(official_authority(X,Y)), blawx_ultimately(official_authority(X,Y)),
      findall(Time,blawx_becomes(-official_authority(X,Y),datetime(Time)),[]).\nblawx_not_interrupted(datetime(bot),-official_authority(X,Y),datetime(eot))
      :- blawx_initially(-official_authority(X,Y)), blawx_ultimately(-official_authority(X,Y)),
      findall(Time,blawx_becomes(official_authority(X,Y),datetime(Time)),[]).\nblawx_as_of(official_authority(X,Y),datetime(Time))
      :- blawx_initially(official_authority(X,Y)), BeforeT #< Time,blawx_not_interrupted(datetime(bot),official_authority(X,Y),datetime(BeforeT)).\nblawx_as_of(official_authority(X,Y),datetime(Time))
      :- blawx_becomes(official_authority(X,Y),datetime(BeforeT)),BeforeT #< Time,blawx_not_interrupted(datetime(BeforeT),official_authority(X,Y),datetime(Time)).\nblawx_as_of(-official_authority(X,Y),datetime(Time))
      :- blawx_initially(-official_authority(X,Y)), BeforeT #< Time,blawx_not_interrupted(datetime(bot),-official_authority(X,Y),datetime(BeforeT)).\nblawx_as_of(-official_authority(X,Y),datetime(Time))
      :- blawx_becomes(-official_authority(X,Y),datetime(BeforeT)),BeforeT #< Time,blawx_not_interrupted(datetime(BeforeT),-official_authority(X,Y),datetime(Time)).\nblawx_during(datetime(Start),official_authority(X,Y),datetime(End))
      :- blawx_becomes(official_authority(X,Y),datetime(Start)), blawx_becomes(-official_authority(X,Y),datetime(End)),
      Start #< End, blawx_not_interrupted(datetime(Start),official_authority(X,Y),datetime(End)).\nblawx_during(datetime(bot),official_authority(X,Y),datetime(End))
      :- blawx_initially(official_authority(X,Y)), blawx_becomes(-official_authority(X,Y),datetime(End)),
      blawx_not_interrupted(datetime(bot),official_authority(X,Y),datetime(End)).\nblawx_during(datetime(Start),official_authority(X,Y),datetime(eot))
      :- blawx_ultimately(official_authority(X,Y)), blawx_becomes(-official_authority(X,Y),datetime(Start)),
      blawx_not_interrupted(datetime(Start),official_authority(X,Y),datetime(eot)).\nblawx_during(datetime(bot),official_authority(X,Y),datetime(eot))
      :- blawx_initially(official_authority(X,Y)), blawx_ultimately(official_authority(X,Y)),
      blawx_becomes(-official_authority(X,Y),datetime(Start)), blawx_not_interrupted(datetime(bot),official_authority(X,Y),datetime(eot)).\nblawx_during(datetime(Start),-official_authority(X,Y),datetime(End))
      :- blawx_becomes(-official_authority(X,Y),datetime(Start)), blawx_becomes(official_authority(X,Y),datetime(End)),
      Start #< End, blawx_not_interrupted(datetime(Start),-official_authority(X,Y),datetime(End)).\nblawx_during(datetime(bot),-official_authority(X,Y),datetime(End))
      :- blawx_initially(-official_authority(X,Y)), blawx_becomes(official_authority(X,Y),datetime(End)),
      blawx_not_interrupted(datetime(bot),-official_authority(X,Y),datetime(End)).\nblawx_during(datetime(Start),-official_authority(X,Y),datetime(eot))
      :- blawx_ultimately(-official_authority(X,Y)), blawx_becomes(official_authority(X,Y),datetime(Start)),
      blawx_not_interrupted(datetime(Start),-official_authority(X,Y),datetime(eot)).\nblawx_during(datetime(bot),-official_authority(X,Y),datetime(eot))
      :- blawx_initially(-official_authority(X,Y)), blawx_ultimately(-official_authority(X,Y)),
      blawx_becomes(-official_authority(X,Y),datetime(Start)), blawx_not_interrupted(datetime(bot),-official_authority(X,Y),datetime(eot)).\n\naccording_to(sec_3_section,-right_to_portability,A,B,C)
      :- data_subject(A),\ndata(B),\ncontroller(C),\npersonal(B,A),\nprocessed_automated(B,C),\ndata_management(C,B,A,consent),\npublic_interest(B,C).\n\n%
      BLAWX CHECK DUPLICATES\nholds(sec_3_section,-right_to_portability,A,B,C) :-
      according_to(sec_3_section,-right_to_portability,A,B,C).\n\n% BLAWX CHECK DUPLICATES\n
      \ -right_to_portability(A,B,C) :- holds(sec_3_section,-right_to_portability,A,B,C)."
