      :-\ndata_subject(A),\ndata(B),\ncontroller(C),\npersonal(B,A),\nprocessed_automated(B,C),\ndata_management(C,B,A,contract).\n\nblawx_category(legal_basis).\nblawx_category_nlg(legal_basis,\"\",\"is
