      :- blawx_initially(-controller(X)), blawx_ultimately(-controller(X)), findall(Time,blawx_becomes(controller(X),datetime(Time)),[]).\nblawx_as_of(controller(X),datetime(Time))
      :- blawx_initially(controller(X)), BeforeT #< Time,blawx_not_interrupted(datetime(bot),controller(X),datetime(BeforeT)).\nblawx_as_of(controller(X),datetime(Time))
      :- blawx_becomes(controller(X),datetime(BeforeT)),BeforeT #< Time,blawx_not_interrupted(datetime(BeforeT),controller(X),datetime(Time)).\nblawx_as_of(-controller(X),datetime(Time))
      :- blawx_initially(-controller(X)), BeforeT #< Time,blawx_not_interrupted(datetime(bot),-controller(X),datetime(BeforeT)).\nblawx_as_of(-controller(X),datetime(Time))
