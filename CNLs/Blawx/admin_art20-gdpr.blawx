    scasp_encoding: "blawx_category(data_subject).\nblawx_category_nlg(data_subject,\"\",\"is
      a data subject\").\n:- dynamic data_subject/1.\n#pred data_subject(X) :: '@(X)
      is a data subject'.\n#pred holds(user,data_subject,X) :: 'it is provided as
      a fact that @(X) is a data subject'.\n#pred holds(user,-data_subject,X) :: 'it
      is provided as a fact that it is not the case that @(X) is a data subject'.\n#pred
      holds(Z,data_subject,X) :: 'the conclusion in @(Z) that @(X) is a data subject
      holds'.\n#pred holds(Z,-data_subject,X) :: 'the conclusion in @(Z) that it is
      not the case that @(X) is a data subject holds'.\n#pred according_to(Z,data_subject,X)
      :: 'according to @(Z), @(X) is a data subject'.\n#pred according_to(Z,-data_subject,X)
      :: 'according to @(Z), it is not the case that @(X) is a data subject'.\n#pred
      blawx_defeated(Z,data_subject,X) :: 'the conclusion in @(Z) that @(X) is a data
      subject is defeated'.\n#pred blawx_defeated(Z,-data_subject,X) :: 'the conclusion
      in @(Z) that it is not the case that @(X) is a data subject is defeated'.\n#pred
      blawx_initially(data_subject(X)) :: 'that @(X) is a data subject holds initially'.\n#pred
      blawx_initially(-data_subject(X)) :: 'that it is not the case that @(X) is a
      data subject holds initially'.\n#pred blawx_ultimately(data_subject(X)) :: 'that
      @(X) is a data subject holds ultimately'.\n#pred blawx_ultimately(-data_subject(X))
      :: 'that it is not the case that @(X) is a data subject holds ultimately'.\n#pred
      blawx_as_of(data_subject(X),T) :: 'that @(X) is a data subject holds at @(T)'.\n#pred
      blawx_as_of(-data_subject(X),T) :: 'that it is not the case that @(X) is a data
      subject holds at @(T)'.\n#pred blawx_during(T1,data_subject(X),T2) :: 'that
      @(X) is a data subject held between @(T1) and @(T2)'.\n#pred blawx_during(T1,-data_subject(X),T2)
      :: 'that it is not the case that @(X) is a data subject held between @(T1) and
      @(T2)'.\n#pred blawx_becomes(data_subject(X),T) :: 'that @(X) is a data subject
      became true at @(T)'.\n#pred blawx_becomes(-data_subject(X),T) :: 'that it is
      not the case that @(X) is a data subject became true at @(T)'.\n#pred blawx_not_interrupted(Start,data_subject(X),End)
      :: '@(X) is a data subject remained the case between @(Start) and @(End)'.\n#pred
      blawx_not_interrupted(Start,-data_subject(X),End) :: 'it is not the case that
      @(X) is a data subject remained the case between @(Start) and @(End)'.\nblawx_not_interrupted(datetime(Start),data_subject(X),datetime(End))
      :- Start \\= bot, End \\= eot, findall(Time,blawx_becomes(-data_subject(X),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).\nblawx_not_interrupted(datetime(Start),-data_subject(X),datetime(End))
      :- Start \\= bot, End \\= eot, findall(Time,blawx_becomes(data_subject(X),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).\nblawx_not_interrupted(datetime(bot),data_subject(X),datetime(End))
      :- End \\= eot, findall(Time,blawx_becomes(-data_subject(X),datetime(Time)),Times),blawx_list_not_before(Times,End).\nblawx_not_interrupted(datetime(bot),-data_subject(X),datetime(End))
      :- End \\= eot, findall(Time,blawx_becomes(data_subject(X),datetime(Time)),Times),blawx_list_not_before(Times,End).\nblawx_not_interrupted(datetime(Start),data_subject(X),datetime(eot))
      :- Start \\= bot, findall(Time,blawx_becomes(-data_subject(X),datetime(Time)),Times),blawx_list_not_after(Times,Start).\nblawx_not_interrupted(datetime(Start),-data_subject(X),datetime(eot))
      :- Start \\= bot, findall(Time,blawx_becomes(data_subject(X),datetime(Time)),Times),blawx_list_not_after(Times,Start).\nblawx_not_interrupted(datetime(bot),data_subject(X),datetime(eot))
      :- blawx_initially(data_subject(X)), blawx_ultimately(data_subject(X)), findall(Time,blawx_becomes(-data_subject(X),datetime(Time)),[]).\nblawx_not_interrupted(datetime(bot),-data_subject(X),datetime(eot))
      :- blawx_initially(-data_subject(X)), blawx_ultimately(-data_subject(X)), findall(Time,blawx_becomes(data_subject(X),datetime(Time)),[]).\nblawx_as_of(data_subject(X),datetime(Time))
      :- blawx_initially(data_subject(X)), BeforeT #< Time,blawx_not_interrupted(datetime(bot),data_subject(X),datetime(BeforeT)).\nblawx_as_of(data_subject(X),datetime(Time))
      :- blawx_becomes(data_subject(X),datetime(BeforeT)),BeforeT #< Time,blawx_not_interrupted(datetime(BeforeT),data_subject(X),datetime(Time)).\nblawx_as_of(-data_subject(X),datetime(Time))
      :- blawx_initially(-data_subject(X)), BeforeT #< Time,blawx_not_interrupted(datetime(bot),-data_subject(X),datetime(BeforeT)).\nblawx_as_of(-data_subject(X),datetime(Time))
      :- blawx_becomes(-data_subject(X),datetime(BeforeT)),BeforeT #< Time,blawx_not_interrupted(datetime(BeforeT),-data_subject(X),datetime(Time)).\nblawx_during(datetime(Start),data_subject(X),datetime(End))
      :- blawx_becomes(data_subject(X),datetime(Start)), blawx_becomes(-data_subject(X),datetime(End)),
      Start #< End, blawx_not_interrupted(datetime(Start),data_subject(X),datetime(End)).\nblawx_during(datetime(bot),data_subject(X),datetime(End))
      :- blawx_initially(data_subject(X)), blawx_becomes(-data_subject(X),datetime(End)),
      blawx_not_interrupted(datetime(bot),data_subject(X),datetime(End)).\nblawx_during(datetime(Start),data_subject(X),datetime(eot))
      :- blawx_ultimately(data_subject(X)), blawx_becomes(-data_subject(X),datetime(Start)),
      blawx_not_interrupted(datetime(Start),data_subject(X),datetime(eot)).\nblawx_during(datetime(bot),data_subject(X),datetime(eot))
      :- blawx_initially(data_subject(X)), blawx_ultimately(data_subject(X)), blawx_becomes(-data_subject(X),datetime(Start)),
      blawx_not_interrupted(datetime(bot),data_subject(X),datetime(eot)).\nblawx_during(datetime(Start),-data_subject(X),datetime(End))
      :- blawx_becomes(-data_subject(X),datetime(Start)), blawx_becomes(data_subject(X),datetime(End)),
      Start #< End, blawx_not_interrupted(datetime(Start),-data_subject(X),datetime(End)).\nblawx_during(datetime(bot),-data_subject(X),datetime(End))
      :- blawx_initially(-data_subject(X)), blawx_becomes(data_subject(X),datetime(End)),
      blawx_not_interrupted(datetime(bot),-data_subject(X),datetime(End)).\nblawx_during(datetime(Start),-data_subject(X),datetime(eot))
      :- blawx_ultimately(-data_subject(X)), blawx_becomes(data_subject(X),datetime(Start)),
      blawx_not_interrupted(datetime(Start),-data_subject(X),datetime(eot)).\nblawx_during(datetime(bot),-data_subject(X),datetime(eot))
      :- blawx_initially(-data_subject(X)), blawx_ultimately(-data_subject(X)), blawx_becomes(-data_subject(X),datetime(Start)),
      blawx_not_interrupted(datetime(bot),-data_subject(X),datetime(eot)).\nblawx_relationship(right_to_portability,data_subject,data,controller).\nblawx_relationship_nlg(right_to_portability,\"\",\"has
      the right to portability on the data \",\" from\",\"\").\n:- dynamic right_to_portability/3.\n#pred
      right_to_portability(A,B,C) :: '@(A) has the right to portability on the data
      \ @(B)  from @(C)'.\n#pred holds(user,right_to_portability,A,B,C) :: 'it is
      provided as a fact that @(A) has the right to portability on the data  @(B)
      \ from @(C)'.\n#pred holds(user,-right_to_portability,A,B,C) :: 'it is provided
      as a fact that it is not the case that @(A) has the right to portability on
      the data  @(B)  from @(C)'.\n#pred holds(Z,right_to_portability,A,B,C) :: 'the
      conclusion in @(Z) that @(A) has the right to portability on the data  @(B)
      \ from @(C) holds'.\n#pred holds(Z,-right_to_portability,A,B,C) :: 'the conclusion
      in @(Z) that it is not the case that @(A) has the right to portability on the
      data  @(B)  from @(C) holds'.\n#pred according_to(Z,right_to_portability,A,B,C)
      :: 'according to @(Z), @(A) has the right to portability on the data  @(B)  from
      @(C)'.\n#pred according_to(Z,-right_to_portability,A,B,C) :: 'according to @(Z),
      it is not the case that @(A) has the right to portability on the data  @(B)
      \ from @(C)'.\n#pred blawx_defeated(Z,right_to_portability,A,B,C) :: 'the conclusion
      in @(Z) that @(A) has the right to portability on the data  @(B)  from @(C)
      is defeated'.\n#pred blawx_defeated(Z,-right_to_portability,A,B,C) :: 'the conclusion
      in @(Z) that @(A) has the right to portability on the data  @(B)  from @(C)
      is defeated'.\n#pred blawx_initially(right_to_portability(A,B,C)) :: 'that @(A)
      has the right to portability on the data  @(B)  from @(C) holds initially'.\n#pred
      blawx_initially(-right_to_portability(A,B,C)) :: 'that it is not the case that
      @(A) has the right to portability on the data  @(B)  from @(C) holds initially'.\n#pred
      blawx_ultimately(right_to_portability(A,B,C)) :: 'that @(A) has the right to
      portability on the data  @(B)  from @(C) holds ultimately'.\n#pred blawx_ultimately(-right_to_portability(A,B,C))
      :: 'that it is not the case that @(A) has the right to portability on the data
      \ @(B)  from @(C) holds ultimately'.\n#pred blawx_as_of(right_to_portability(A,B,C),T)
      :: 'that @(A) has the right to portability on the data  @(B)  from @(C) holds
      at @(T)'.\n#pred blawx_as_of(-right_to_portability(A,B,C),T) :: 'that it is
      not the case that @(A) has the right to portability on the data  @(B)  from
      @(C) holds at @(T)'.\n#pred blawx_during(T1,right_to_portability(A,B,C),T2)
      :: 'that @(A) has the right to portability on the data  @(B)  from @(C) held
      between @(T1) and @(T2)'.\n#pred blawx_during(T1,-right_to_portability(A,B,C),T2)
      :: 'that it is not the case that @(A) has the right to portability on the data
      \ @(B)  from @(C) held between @(T1) and @(T2)'.\n#pred blawx_becomes(right_to_portability(A,B,C),T)
      :: 'that @(A) has the right to portability on the data  @(B)  from @(C) became
      true at @(T)'.\n#pred blawx_becomes(-right_to_portability(A,B,C),T) :: 'that
      it is not the case that @(A) has the right to portability on the data  @(B)
      \ from @(C) became true at @(T)'.\n#pred blawx_not_interrupted(Start,right_to_portability(A,B,C),End)
      :: '@(A) has the right to portability on the data  @(B)  from @(C) remained
      the case between @(Start) and @(End)'.\n#pred blawx_not_interrupted(Start,-right_to_portability(A,B,C),End)
      :: 'it is not the case that @(A) has the right to portability on the data  @(B)
      \ from @(C) remained the case between @(Start) and @(End)'.\nblawx_not_interrupted(datetime(Start),right_to_portability(A,B,C),datetime(End))
      :- Start \\= bot, End \\= eot, findall(Time,blawx_becomes(-right_to_portability(A,B,C),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).\nblawx_not_interrupted(datetime(Start),-right_to_portability(A,B,C),datetime(End))
      :- Start \\= bot, End \\= eot, findall(Time,blawx_becomes(right_to_portability(A,B,C),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).\nblawx_not_interrupted(datetime(bot),right_to_portability(A,B,C),datetime(End))
      :- End \\= eot, findall(Time,blawx_becomes(-right_to_portability(A,B,C),datetime(Time)),Times),blawx_list_not_before(Times,End).\nblawx_not_interrupted(datetime(bot),-right_to_portability(A,B,C),datetime(End))
      :- End \\= eot, findall(Time,blawx_becomes(right_to_portability(A,B,C),datetime(Time)),Times),blawx_list_not_before(Times,End).\nblawx_not_interrupted(datetime(Start),right_to_portability(A,B,C),datetime(eot))
      :- Start \\= bot, findall(Time,blawx_becomes(-right_to_portability(A,B,C),datetime(Time)),Times),blawx_list_not_after(Times,Start).\nblawx_not_interrupted(datetime(Start),-right_to_portability(A,B,C),datetime(eot))
      :- Start \\= bot, findall(Time,blawx_becomes(right_to_portability(A,B,C),datetime(Time)),Times),blawx_list_not_after(Times,Start).\nblawx_not_interrupted(datetime(bot),right_to_portability(A,B,C),datetime(eot))
      :- blawx_initially(right_to_portability(A,B,C)), blawx_ultimately(right_to_portability(A,B,C)),
      findall(Time,blawx_becomes(-right_to_portability(A,B,C),datetime(Time)),[]).\nblawx_not_interrupted(datetime(bot),-right_to_portability(A,B,C),datetime(eot))
      :- blawx_initially(-right_to_portability(A,B,C)), blawx_ultimately(-right_to_portability(A,B,C)),
      findall(Time,blawx_becomes(right_to_portability(A,B,C),datetime(Time)),[]).\nblawx_as_of(right_to_portability(A,B,C),datetime(Time))
      :- blawx_initially(right_to_portability(A,B,C)), BeforeT #< Time,blawx_not_interrupted(datetime(bot),right_to_portability(A,B,C),datetime(BeforeT)).\nblawx_as_of(right_to_portability(A,B,C),datetime(Time))
      :- blawx_becomes(right_to_portability(A,B,C),datetime(BeforeT)),BeforeT #< Time,blawx_not_interrupted(datetime(BeforeT),right_to_portability(A,B,C),datetime(Time)).\nblawx_as_of(-right_to_portability(A,B,C),datetime(Time))
      :- blawx_initially(-right_to_portability(A,B,C)), BeforeT #< Time,blawx_not_interrupted(datetime(bot),-right_to_portability(A,B,C),datetime(BeforeT)).\nblawx_as_of(-right_to_portability(A,B,C),datetime(Time))
      :- blawx_becomes(-right_to_portability(A,B,C),datetime(BeforeT)),BeforeT #<
      Time,blawx_not_interrupted(datetime(BeforeT),-right_to_portability(A,B,C),datetime(Time)).\nblawx_during(datetime(Start),right_to_portability(A,B,C),datetime(End))
      :- blawx_becomes(right_to_portability(A,B,C),datetime(Start)), blawx_becomes(-right_to_portability(A,B,C),datetime(End)),
      Start #< End, blawx_not_interrupted(datetime(Start),right_to_portability(A,B,C),datetime(End)).\nblawx_during(datetime(bot),right_to_portability(A,B,C),datetime(End))
      :- blawx_initially(right_to_portability(A,B,C)), blawx_becomes(-right_to_portability(A,B,C),datetime(End)),
      blawx_not_interrupted(datetime(bot),right_to_portability(A,B,C),datetime(End)).\nblawx_during(datetime(Start),right_to_portability(A,B,C),datetime(eot))
      :- blawx_ultimately(right_to_portability(A,B,C)), blawx_becomes(-right_to_portability(A,B,C),datetime(Start)),
      blawx_not_interrupted(datetime(Start),right_to_portability(A,B,C),datetime(eot)).\nblawx_during(datetime(bot),right_to_portability(A,B,C),datetime(eot))
      :- blawx_initially(right_to_portability(A,B,C)), blawx_ultimately(right_to_portability(A,B,C)),
      blawx_becomes(-right_to_portability(A,B,C),datetime(Start)), blawx_not_interrupted(datetime(bot),right_to_portability(A,B,C),datetime(eot)).\nblawx_during(datetime(Start),-right_to_portability(A,B,C),datetime(End))
      :- blawx_becomes(-right_to_portability(A,B,C),datetime(Start)), blawx_becomes(right_to_portability(A,B,C),datetime(End)),
      Start #< End, blawx_not_interrupted(datetime(Start),-right_to_portability(A,B,C),datetime(End)).\nblawx_during(datetime(bot),-right_to_portability(A,B,C),datetime(End))
      :- blawx_initially(-right_to_portability(A,B,C)), blawx_becomes(right_to_portability(A,B,C),datetime(End)),
      blawx_not_interrupted(datetime(bot),-right_to_portability(A,B,C),datetime(End)).\nblawx_during(datetime(Start),-right_to_portability(A,B,C),datetime(eot))
      :- blawx_ultimately(-right_to_portability(A,B,C)), blawx_becomes(right_to_portability(A,B,C),datetime(Start)),
      blawx_not_interrupted(datetime(Start),-right_to_portability(A,B,C),datetime(eot)).\nblawx_during(datetime(bot),-right_to_portability(A,B,C),datetime(eot))
      :- blawx_initially(-right_to_portability(A,B,C)), blawx_ultimately(-right_to_portability(A,B,C)),
      blawx_becomes(-right_to_portability(A,B,C),datetime(Start)), blawx_not_interrupted(datetime(bot),-right_to_portability(A,B,C),datetime(eot)).\n\naccording_to(sec_1_section,right_to_portability,A,B,C)
      :- data_subject(A),\ndata(B),\ncontroller(C),\npersonal(B,A),\nprocessed_automated(B,C),\ndata_management(C,B,A,consent).\n\n%
      BLAWX CHECK DUPLICATES\nholds(sec_1_section,right_to_portability,A,B,C) :- according_to(sec_1_section,right_to_portability,A,B,C),
      not blawx_defeated(sec_1_section,right_to_portability,A,B,C).\n\n% BLAWX CHECK
      DUPLICATES\n  right_to_portability(A,B,C) :- holds(sec_1_section,right_to_portability,A,B,C).\n\nblawx_category(data).\nblawx_category_nlg(data,\"\",\"is
      personal data\").\n:- dynamic data/1.\n#pred data(X) :: '@(X) is personal data'.\n#pred
      holds(user,data,X) :: 'it is provided as a fact that @(X) is personal data'.\n#pred
      holds(user,-data,X) :: 'it is provided as a fact that it is not the case that
