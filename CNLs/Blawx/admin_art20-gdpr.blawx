    scasp_encoding: 'blawx_relationship(right_to_direct_transmission,data_subject,data,controller).

      blawx_relationship_nlg(right_to_direct_transmission,"","has the right to have
      his data","transmitted directly from","to another controller").

      :- dynamic right_to_direct_transmission/3.

      #pred right_to_direct_transmission(A,B,C) :: ''@(A) has the right to have his
      data @(B) transmitted directly from @(C) to another controller''.

      #pred holds(user,right_to_direct_transmission,A,B,C) :: ''it is provided as
      a fact that @(A) has the right to have his data @(B) transmitted directly from
      @(C) to another controller''.

      #pred holds(user,-right_to_direct_transmission,A,B,C) :: ''it is provided as
      a fact that it is not the case that @(A) has the right to have his data @(B)
      transmitted directly from @(C) to another controller''.

      #pred holds(Z,right_to_direct_transmission,A,B,C) :: ''the conclusion in @(Z)
      that @(A) has the right to have his data @(B) transmitted directly from @(C)
      to another controller holds''.

      #pred holds(Z,-right_to_direct_transmission,A,B,C) :: ''the conclusion in @(Z)
      that it is not the case that @(A) has the right to have his data @(B) transmitted
      directly from @(C) to another controller holds''.

      #pred according_to(Z,right_to_direct_transmission,A,B,C) :: ''according to @(Z),
      @(A) has the right to have his data @(B) transmitted directly from @(C) to another
      controller''.

      #pred according_to(Z,-right_to_direct_transmission,A,B,C) :: ''according to
      @(Z), it is not the case that @(A) has the right to have his data @(B) transmitted
      directly from @(C) to another controller''.

      #pred blawx_defeated(Z,right_to_direct_transmission,A,B,C) :: ''the conclusion
      in @(Z) that @(A) has the right to have his data @(B) transmitted directly from
      @(C) to another controller is defeated''.

      #pred blawx_defeated(Z,-right_to_direct_transmission,A,B,C) :: ''the conclusion
      in @(Z) that @(A) has the right to have his data @(B) transmitted directly from
      @(C) to another controller is defeated''.

      #pred blawx_initially(right_to_direct_transmission(A,B,C)) :: ''that @(A) has
      the right to have his data @(B) transmitted directly from @(C) to another controller
      holds initially''.

      #pred blawx_initially(-right_to_direct_transmission(A,B,C)) :: ''that it is
      not the case that @(A) has the right to have his data @(B) transmitted directly
      from @(C) to another controller holds initially''.

      #pred blawx_ultimately(right_to_direct_transmission(A,B,C)) :: ''that @(A) has
      the right to have his data @(B) transmitted directly from @(C) to another controller
      holds ultimately''.

      #pred blawx_ultimately(-right_to_direct_transmission(A,B,C)) :: ''that it is
      not the case that @(A) has the right to have his data @(B) transmitted directly
      from @(C) to another controller holds ultimately''.

      #pred blawx_as_of(right_to_direct_transmission(A,B,C),T) :: ''that @(A) has
      the right to have his data @(B) transmitted directly from @(C) to another controller
      holds at @(T)''.

      #pred blawx_as_of(-right_to_direct_transmission(A,B,C),T) :: ''that it is not
      the case that @(A) has the right to have his data @(B) transmitted directly
      from @(C) to another controller holds at @(T)''.

      #pred blawx_during(T1,right_to_direct_transmission(A,B,C),T2) :: ''that @(A)
      has the right to have his data @(B) transmitted directly from @(C) to another
      controller held between @(T1) and @(T2)''.

      #pred blawx_during(T1,-right_to_direct_transmission(A,B,C),T2) :: ''that it
      is not the case that @(A) has the right to have his data @(B) transmitted directly
      from @(C) to another controller held between @(T1) and @(T2)''.

      #pred blawx_becomes(right_to_direct_transmission(A,B,C),T) :: ''that @(A) has
      the right to have his data @(B) transmitted directly from @(C) to another controller
      became true at @(T)''.

      #pred blawx_becomes(-right_to_direct_transmission(A,B,C),T) :: ''that it is
      not the case that @(A) has the right to have his data @(B) transmitted directly
      from @(C) to another controller became true at @(T)''.

      #pred blawx_not_interrupted(Start,right_to_direct_transmission(A,B,C),End) ::
      ''@(A) has the right to have his data @(B) transmitted directly from @(C) to
      another controller remained the case between @(Start) and @(End)''.

      #pred blawx_not_interrupted(Start,-right_to_direct_transmission(A,B,C),End)
      :: ''it is not the case that @(A) has the right to have his data @(B) transmitted
      directly from @(C) to another controller remained the case between @(Start)
      and @(End)''.

      blawx_not_interrupted(datetime(Start),right_to_direct_transmission(A,B,C),datetime(End))
      :- Start \= bot, End \= eot, findall(Time,blawx_becomes(-right_to_direct_transmission(A,B,C),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).

      blawx_not_interrupted(datetime(Start),-right_to_direct_transmission(A,B,C),datetime(End))
      :- Start \= bot, End \= eot, findall(Time,blawx_becomes(right_to_direct_transmission(A,B,C),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).

      blawx_not_interrupted(datetime(bot),right_to_direct_transmission(A,B,C),datetime(End))
      :- End \= eot, findall(Time,blawx_becomes(-right_to_direct_transmission(A,B,C),datetime(Time)),Times),blawx_list_not_before(Times,End).

      blawx_not_interrupted(datetime(bot),-right_to_direct_transmission(A,B,C),datetime(End))
      :- End \= eot, findall(Time,blawx_becomes(right_to_direct_transmission(A,B,C),datetime(Time)),Times),blawx_list_not_before(Times,End).

      blawx_not_interrupted(datetime(Start),right_to_direct_transmission(A,B,C),datetime(eot))
      :- Start \= bot, findall(Time,blawx_becomes(-right_to_direct_transmission(A,B,C),datetime(Time)),Times),blawx_list_not_after(Times,Start).

      blawx_not_interrupted(datetime(Start),-right_to_direct_transmission(A,B,C),datetime(eot))
      :- Start \= bot, findall(Time,blawx_becomes(right_to_direct_transmission(A,B,C),datetime(Time)),Times),blawx_list_not_after(Times,Start).

      blawx_not_interrupted(datetime(bot),right_to_direct_transmission(A,B,C),datetime(eot))
      :- blawx_initially(right_to_direct_transmission(A,B,C)), blawx_ultimately(right_to_direct_transmission(A,B,C)),
      findall(Time,blawx_becomes(-right_to_direct_transmission(A,B,C),datetime(Time)),[]).

      blawx_not_interrupted(datetime(bot),-right_to_direct_transmission(A,B,C),datetime(eot))
      :- blawx_initially(-right_to_direct_transmission(A,B,C)), blawx_ultimately(-right_to_direct_transmission(A,B,C)),
      findall(Time,blawx_becomes(right_to_direct_transmission(A,B,C),datetime(Time)),[]).

      blawx_as_of(right_to_direct_transmission(A,B,C),datetime(Time)) :- blawx_initially(right_to_direct_transmission(A,B,C)),
      BeforeT #< Time,blawx_not_interrupted(datetime(bot),right_to_direct_transmission(A,B,C),datetime(BeforeT)).

      blawx_as_of(right_to_direct_transmission(A,B,C),datetime(Time)) :- blawx_becomes(right_to_direct_transmission(A,B,C),datetime(BeforeT)),BeforeT
      #< Time,blawx_not_interrupted(datetime(BeforeT),right_to_direct_transmission(A,B,C),datetime(Time)).

      blawx_as_of(-right_to_direct_transmission(A,B,C),datetime(Time)) :- blawx_initially(-right_to_direct_transmission(A,B,C)),
      BeforeT #< Time,blawx_not_interrupted(datetime(bot),-right_to_direct_transmission(A,B,C),datetime(BeforeT)).

      blawx_as_of(-right_to_direct_transmission(A,B,C),datetime(Time)) :- blawx_becomes(-right_to_direct_transmission(A,B,C),datetime(BeforeT)),BeforeT
      #< Time,blawx_not_interrupted(datetime(BeforeT),-right_to_direct_transmission(A,B,C),datetime(Time)).

      blawx_during(datetime(Start),right_to_direct_transmission(A,B,C),datetime(End))
      :- blawx_becomes(right_to_direct_transmission(A,B,C),datetime(Start)), blawx_becomes(-right_to_direct_transmission(A,B,C),datetime(End)),
      Start #< End, blawx_not_interrupted(datetime(Start),right_to_direct_transmission(A,B,C),datetime(End)).

      blawx_during(datetime(bot),right_to_direct_transmission(A,B,C),datetime(End))
      :- blawx_initially(right_to_direct_transmission(A,B,C)), blawx_becomes(-right_to_direct_transmission(A,B,C),datetime(End)),
      blawx_not_interrupted(datetime(bot),right_to_direct_transmission(A,B,C),datetime(End)).

      blawx_during(datetime(Start),right_to_direct_transmission(A,B,C),datetime(eot))
      :- blawx_ultimately(right_to_direct_transmission(A,B,C)), blawx_becomes(-right_to_direct_transmission(A,B,C),datetime(Start)),
      blawx_not_interrupted(datetime(Start),right_to_direct_transmission(A,B,C),datetime(eot)).

      blawx_during(datetime(bot),right_to_direct_transmission(A,B,C),datetime(eot))
      :- blawx_initially(right_to_direct_transmission(A,B,C)), blawx_ultimately(right_to_direct_transmission(A,B,C)),
      blawx_becomes(-right_to_direct_transmission(A,B,C),datetime(Start)), blawx_not_interrupted(datetime(bot),right_to_direct_transmission(A,B,C),datetime(eot)).

      blawx_during(datetime(Start),-right_to_direct_transmission(A,B,C),datetime(End))
      :- blawx_becomes(-right_to_direct_transmission(A,B,C),datetime(Start)), blawx_becomes(right_to_direct_transmission(A,B,C),datetime(End)),
      Start #< End, blawx_not_interrupted(datetime(Start),-right_to_direct_transmission(A,B,C),datetime(End)).

      blawx_during(datetime(bot),-right_to_direct_transmission(A,B,C),datetime(End))
      :- blawx_initially(-right_to_direct_transmission(A,B,C)), blawx_becomes(right_to_direct_transmission(A,B,C),datetime(End)),
      blawx_not_interrupted(datetime(bot),-right_to_direct_transmission(A,B,C),datetime(End)).

      blawx_during(datetime(Start),-right_to_direct_transmission(A,B,C),datetime(eot))
      :- blawx_ultimately(-right_to_direct_transmission(A,B,C)), blawx_becomes(right_to_direct_transmission(A,B,C),datetime(Start)),
      blawx_not_interrupted(datetime(Start),-right_to_direct_transmission(A,B,C),datetime(eot)).

      blawx_during(datetime(bot),-right_to_direct_transmission(A,B,C),datetime(eot))
      :- blawx_initially(-right_to_direct_transmission(A,B,C)), blawx_ultimately(-right_to_direct_transmission(A,B,C)),
      blawx_becomes(-right_to_direct_transmission(A,B,C),datetime(Start)), blawx_not_interrupted(datetime(bot),-right_to_direct_transmission(A,B,C),datetime(eot)).


      right_to_direct_transmission(A,B,C) :-

      right_to_portability(A,B,C).'
