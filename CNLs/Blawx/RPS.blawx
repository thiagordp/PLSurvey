    scasp_encoding: 'winner(Player1) :-

      player(Player1),

      player(Player2),

      move(Player1,rock),

      move(Player2,scissor).


      blawx_category(player).

      blawx_category_nlg(player,"","is a player").

      :- dynamic player/1.

      #pred player(X) :: ''@(X) is a player''.

      #pred holds(user,player,X) :: ''it is provided as a fact that @(X) is a player''.

      #pred holds(user,-player,X) :: ''it is provided as a fact that it is not the
      case that @(X) is a player''.

      #pred holds(Z,player,X) :: ''the conclusion in @(Z) that @(X) is a player holds''.

      #pred holds(Z,-player,X) :: ''the conclusion in @(Z) that it is not the case
      that @(X) is a player holds''.

      #pred according_to(Z,player,X) :: ''according to @(Z), @(X) is a player''.

      #pred according_to(Z,-player,X) :: ''according to @(Z), it is not the case that
      @(X) is a player''.

      #pred blawx_defeated(Z,player,X) :: ''the conclusion in @(Z) that @(X) is a
      player is defeated''.

      #pred blawx_defeated(Z,-player,X) :: ''the conclusion in @(Z) that it is not
      the case that @(X) is a player is defeated''.

      #pred blawx_initially(player(X)) :: ''that @(X) is a player holds initially''.

      #pred blawx_initially(-player(X)) :: ''that it is not the case that @(X) is
      a player holds initially''.

      #pred blawx_ultimately(player(X)) :: ''that @(X) is a player holds ultimately''.

      #pred blawx_ultimately(-player(X)) :: ''that it is not the case that @(X) is
      a player holds ultimately''.

      #pred blawx_as_of(player(X),T) :: ''that @(X) is a player holds at @(T)''.

      #pred blawx_as_of(-player(X),T) :: ''that it is not the case that @(X) is a
      player holds at @(T)''.

      #pred blawx_during(T1,player(X),T2) :: ''that @(X) is a player held between
      @(T1) and @(T2)''.

      #pred blawx_during(T1,-player(X),T2) :: ''that it is not the case that @(X)
      is a player held between @(T1) and @(T2)''.

      #pred blawx_becomes(player(X),T) :: ''that @(X) is a player became true at @(T)''.

      #pred blawx_becomes(-player(X),T) :: ''that it is not the case that @(X) is
      a player became true at @(T)''.

      #pred blawx_not_interrupted(Start,player(X),End) :: ''@(X) is a player remained
      the case between @(Start) and @(End)''.

      #pred blawx_not_interrupted(Start,-player(X),End) :: ''it is not the case that
      @(X) is a player remained the case between @(Start) and @(End)''.

      blawx_not_interrupted(datetime(Start),player(X),datetime(End)) :- Start \= bot,
      End \= eot, findall(Time,blawx_becomes(-player(X),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).

      blawx_not_interrupted(datetime(Start),-player(X),datetime(End)) :- Start \=
      bot, End \= eot, findall(Time,blawx_becomes(player(X),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).

      blawx_not_interrupted(datetime(bot),player(X),datetime(End)) :- End \= eot,
      findall(Time,blawx_becomes(-player(X),datetime(Time)),Times),blawx_list_not_before(Times,End).

      blawx_not_interrupted(datetime(bot),-player(X),datetime(End)) :- End \= eot,
      findall(Time,blawx_becomes(player(X),datetime(Time)),Times),blawx_list_not_before(Times,End).

      blawx_not_interrupted(datetime(Start),player(X),datetime(eot)) :- Start \= bot,
      findall(Time,blawx_becomes(-player(X),datetime(Time)),Times),blawx_list_not_after(Times,Start).

      blawx_not_interrupted(datetime(Start),-player(X),datetime(eot)) :- Start \=
      bot, findall(Time,blawx_becomes(player(X),datetime(Time)),Times),blawx_list_not_after(Times,Start).

      blawx_not_interrupted(datetime(bot),player(X),datetime(eot)) :- blawx_initially(player(X)),
      blawx_ultimately(player(X)), findall(Time,blawx_becomes(-player(X),datetime(Time)),[]).

      blawx_not_interrupted(datetime(bot),-player(X),datetime(eot)) :- blawx_initially(-player(X)),
      blawx_ultimately(-player(X)), findall(Time,blawx_becomes(player(X),datetime(Time)),[]).

      blawx_as_of(player(X),datetime(Time)) :- blawx_initially(player(X)), BeforeT
      #< Time,blawx_not_interrupted(datetime(bot),player(X),datetime(BeforeT)).

      blawx_as_of(player(X),datetime(Time)) :- blawx_becomes(player(X),datetime(BeforeT)),BeforeT
      #< Time,blawx_not_interrupted(datetime(BeforeT),player(X),datetime(Time)).

      blawx_as_of(-player(X),datetime(Time)) :- blawx_initially(-player(X)), BeforeT
      #< Time,blawx_not_interrupted(datetime(bot),-player(X),datetime(BeforeT)).

      blawx_as_of(-player(X),datetime(Time)) :- blawx_becomes(-player(X),datetime(BeforeT)),BeforeT
      #< Time,blawx_not_interrupted(datetime(BeforeT),-player(X),datetime(Time)).

      blawx_during(datetime(Start),player(X),datetime(End)) :- blawx_becomes(player(X),datetime(Start)),
      blawx_becomes(-player(X),datetime(End)), Start #< End, blawx_not_interrupted(datetime(Start),player(X),datetime(End)).

      blawx_during(datetime(bot),player(X),datetime(End)) :- blawx_initially(player(X)),
      blawx_becomes(-player(X),datetime(End)), blawx_not_interrupted(datetime(bot),player(X),datetime(End)).

      blawx_during(datetime(Start),player(X),datetime(eot)) :- blawx_ultimately(player(X)),
      blawx_becomes(-player(X),datetime(Start)), blawx_not_interrupted(datetime(Start),player(X),datetime(eot)).

      blawx_during(datetime(bot),player(X),datetime(eot)) :- blawx_initially(player(X)),
      blawx_ultimately(player(X)), blawx_becomes(-player(X),datetime(Start)), blawx_not_interrupted(datetime(bot),player(X),datetime(eot)).

      blawx_during(datetime(Start),-player(X),datetime(End)) :- blawx_becomes(-player(X),datetime(Start)),
      blawx_becomes(player(X),datetime(End)), Start #< End, blawx_not_interrupted(datetime(Start),-player(X),datetime(End)).

      blawx_during(datetime(bot),-player(X),datetime(End)) :- blawx_initially(-player(X)),
      blawx_becomes(player(X),datetime(End)), blawx_not_interrupted(datetime(bot),-player(X),datetime(End)).

      blawx_during(datetime(Start),-player(X),datetime(eot)) :- blawx_ultimately(-player(X)),
      blawx_becomes(player(X),datetime(Start)), blawx_not_interrupted(datetime(Start),-player(X),datetime(eot)).

      blawx_during(datetime(bot),-player(X),datetime(eot)) :- blawx_initially(-player(X)),
      blawx_ultimately(-player(X)), blawx_becomes(-player(X),datetime(Start)), blawx_not_interrupted(datetime(bot),-player(X),datetime(eot)).

      blawx_attribute(player,move,sign).

      blawx_attribute_nlg(move,ov,"","plays","").

      :- dynamic move/2.

      #pred move(X,Y) :: ''@(X) plays @(Y)''.

      #pred holds(user,move,X,Y) :: ''it is provided as a fact that @(X) plays @(Y)''.

      #pred holds(user,-move,X,Y) :: ''it is provided as a fact that it is not the
      case that @(X) plays @(Y)''.

      #pred holds(Z,move,X,Y) :: ''the conclusion in @(Z) that @(X) plays @(Y) holds''.

      #pred holds(Z,-move,X,Y) :: ''the conclusion in @(Z) that it is not the case
      that @(X) plays @(Y) holds''.

      #pred according_to(Z,move,X,Y) :: ''according to @(Z), @(X) plays @(Y)''.

      #pred according_to(Z,-move,X,Y) :: ''according to @(Z), it is not the case that
      @(X) plays @(Y)''.

      #pred blawx_defeated(Z,move,X,Y) :: ''the conclusion in @(Z) that @(X) plays
      @(Y) is defeated''.

      #pred blawx_defeated(Z,-move,X,Y) :: ''the conclusion in @(Z) that @(X) plays
      @(Y) is defeated''.

      #pred blawx_initially(move(X,Y)) :: ''that @(X) plays @(Y) holds initially''.

      #pred blawx_initially(-move(X,Y)) :: ''that it is not the case that @(X) plays
      @(Y) holds initially''.

      #pred blawx_ultimately(move(X,Y)) :: ''that @(X) plays @(Y) holds ultimately''.

      #pred blawx_ultimately(-move(X,Y)) :: ''that it is not the case that @(X) plays
      @(Y) holds ultimately''.

      #pred blawx_as_of(move(X,Y),T) :: ''that @(X) plays @(Y) holds at @(T)''.

      #pred blawx_as_of(-move(X,Y),T) :: ''that it is not the case that @(X) plays
      @(Y) holds at @(T)''.

      #pred blawx_during(T1,move(X,Y),T2) :: ''that @(X) plays @(Y) held between @(T1)
      and @(T2)''.

      #pred blawx_during(T1,-move(X,Y),T2) :: ''that it is not the case that @(X)
      plays @(Y) held between @(T1) and @(T2)''.

      #pred blawx_becomes(move(X,Y),T) :: ''that @(X) plays @(Y) became true at @(T)''.

      #pred blawx_becomes(-move(X,Y),T) :: ''that it is not the case that @(X) plays
      @(Y) became true at @(T)''.

      #pred blawx_not_interrupted(Start,move(X,Y),End) :: ''@(X) plays @(Y) remained
      the case between @(Start) and @(End)''.

      #pred blawx_not_interrupted(Start,-move(X,Y),End) :: ''it is not the case that
      @(X) plays @(Y) remained the case between @(Start) and @(End)''.

      blawx_not_interrupted(datetime(Start),move(X,Y),datetime(End)) :- Start \= bot,
      End \= eot, findall(Time,blawx_becomes(-move(X,Y),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).

      blawx_not_interrupted(datetime(Start),-move(X,Y),datetime(End)) :- Start \=
      bot, End \= eot, findall(Time,blawx_becomes(move(X,Y),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).

      blawx_not_interrupted(datetime(bot),move(X,Y),datetime(End)) :- End \= eot,
      findall(Time,blawx_becomes(-move(X,Y),datetime(Time)),Times),blawx_list_not_before(Times,End).

      blawx_not_interrupted(datetime(bot),-move(X,Y),datetime(End)) :- End \= eot,
      findall(Time,blawx_becomes(move(X,Y),datetime(Time)),Times),blawx_list_not_before(Times,End).

      blawx_not_interrupted(datetime(Start),move(X,Y),datetime(eot)) :- Start \= bot,
      findall(Time,blawx_becomes(-move(X,Y),datetime(Time)),Times),blawx_list_not_after(Times,Start).

      blawx_not_interrupted(datetime(Start),-move(X,Y),datetime(eot)) :- Start \=
      bot, findall(Time,blawx_becomes(move(X,Y),datetime(Time)),Times),blawx_list_not_after(Times,Start).

      blawx_not_interrupted(datetime(bot),move(X,Y),datetime(eot)) :- blawx_initially(move(X,Y)),
      blawx_ultimately(move(X,Y)), findall(Time,blawx_becomes(-move(X,Y),datetime(Time)),[]).

      blawx_not_interrupted(datetime(bot),-move(X,Y),datetime(eot)) :- blawx_initially(-move(X,Y)),
      blawx_ultimately(-move(X,Y)), findall(Time,blawx_becomes(move(X,Y),datetime(Time)),[]).

      blawx_as_of(move(X,Y),datetime(Time)) :- blawx_initially(move(X,Y)), BeforeT
      #< Time,blawx_not_interrupted(datetime(bot),move(X,Y),datetime(BeforeT)).

      blawx_as_of(move(X,Y),datetime(Time)) :- blawx_becomes(move(X,Y),datetime(BeforeT)),BeforeT
      #< Time,blawx_not_interrupted(datetime(BeforeT),move(X,Y),datetime(Time)).

      blawx_as_of(-move(X,Y),datetime(Time)) :- blawx_initially(-move(X,Y)), BeforeT
      #< Time,blawx_not_interrupted(datetime(bot),-move(X,Y),datetime(BeforeT)).

      blawx_as_of(-move(X,Y),datetime(Time)) :- blawx_becomes(-move(X,Y),datetime(BeforeT)),BeforeT
      #< Time,blawx_not_interrupted(datetime(BeforeT),-move(X,Y),datetime(Time)).

      blawx_during(datetime(Start),move(X,Y),datetime(End)) :- blawx_becomes(move(X,Y),datetime(Start)),
      blawx_becomes(-move(X,Y),datetime(End)), Start #< End, blawx_not_interrupted(datetime(Start),move(X,Y),datetime(End)).

      blawx_during(datetime(bot),move(X,Y),datetime(End)) :- blawx_initially(move(X,Y)),
      blawx_becomes(-move(X,Y),datetime(End)), blawx_not_interrupted(datetime(bot),move(X,Y),datetime(End)).

      blawx_during(datetime(Start),move(X,Y),datetime(eot)) :- blawx_ultimately(move(X,Y)),
      blawx_becomes(-move(X,Y),datetime(Start)), blawx_not_interrupted(datetime(Start),move(X,Y),datetime(eot)).

      blawx_during(datetime(bot),move(X,Y),datetime(eot)) :- blawx_initially(move(X,Y)),
      blawx_ultimately(move(X,Y)), blawx_becomes(-move(X,Y),datetime(Start)), blawx_not_interrupted(datetime(bot),move(X,Y),datetime(eot)).

      blawx_during(datetime(Start),-move(X,Y),datetime(End)) :- blawx_becomes(-move(X,Y),datetime(Start)),
      blawx_becomes(move(X,Y),datetime(End)), Start #< End, blawx_not_interrupted(datetime(Start),-move(X,Y),datetime(End)).

      blawx_during(datetime(bot),-move(X,Y),datetime(End)) :- blawx_initially(-move(X,Y)),
      blawx_becomes(move(X,Y),datetime(End)), blawx_not_interrupted(datetime(bot),-move(X,Y),datetime(End)).

      blawx_during(datetime(Start),-move(X,Y),datetime(eot)) :- blawx_ultimately(-move(X,Y)),
      blawx_becomes(move(X,Y),datetime(Start)), blawx_not_interrupted(datetime(Start),-move(X,Y),datetime(eot)).

      blawx_during(datetime(bot),-move(X,Y),datetime(eot)) :- blawx_initially(-move(X,Y)),
      blawx_ultimately(-move(X,Y)), blawx_becomes(-move(X,Y),datetime(Start)), blawx_not_interrupted(datetime(bot),-move(X,Y),datetime(eot)).

      blawx_attribute(player,winner,boolean).

      blawx_attribute_nlg(winner,not_applicable,"",not_applicable,"is the winner").

      :- dynamic winner/1.

      #pred winner(X) :: ''@(X) is the winner''.

      #pred holds(user,winner,X) :: ''it is provided as a fact that @(X) is the winner''.

      #pred holds(user,-winner,X) :: ''it is provided as a fact that it is not the
      case that @(X) is the winner''.

      #pred holds(Z,winner,X) :: ''the conclusion in @(Z) that @(X) is the winner
      holds''.

      #pred holds(Z,-winner,X) :: ''the conclusion in @(Z) that it is not the case
      that @(X) is the winner holds''.

      #pred according_to(Z,winner,X) :: ''according to @(Z), @(X) is the winner''.

      #pred according_to(Z,-winner,X) :: ''according to @(Z), it is not the case that
      @(X) is the winner''.

      #pred blawx_defeated(Z,winner,X) :: ''the conclusion in @(Z) that @(X) is the
      winner is defeated''.

      #pred blawx_defeated(Z,-winner,X) :: ''the conclusion in @(Z) that @(X) is the
      winner is defeated''.

      #pred blawx_initially(winner(X)) :: ''that @(X) is the winner holds initially''.

      #pred blawx_initially(-winner(X)) :: ''that it is not the case that @(X) is
      the winner holds initially''.

      #pred blawx_ultimately(winner(X)) :: ''that @(X) is the winner holds ultimately''.

      #pred blawx_ultimately(-winner(X)) :: ''that it is not the case that @(X) is
      the winner holds ultimately''.

      #pred blawx_as_of(winner(X),T) :: ''that @(X) is the winner holds at @(T)''.

      #pred blawx_as_of(-winner(X),T) :: ''that it is not the case that @(X) is the
      winner holds at @(T)''.

      #pred blawx_during(T1,winner(X),T2) :: ''that @(X) is the winner held between
      @(T1) and @(T2)''.

      #pred blawx_during(T1,-winner(X),T2) :: ''that it is not the case that @(X)
      is the winner held between @(T1) and @(T2)''.

      #pred blawx_becomes(winner(X),T) :: ''that @(X) is the winner became true at
      @(T)''.

      #pred blawx_becomes(-winner(X),T) :: ''that it is not the case that @(X) is
      the winner became true at @(T)''.

      #pred blawx_not_interrupted(Start,winner(X),End) :: ''@(X) is the winner remained
      the case between @(Start) and @(End)''.

      #pred blawx_not_interrupted(Start,-winner(X),End) :: ''it is not the case that
      @(X) is the winner remained the case between @(Start) and @(End)''.

      blawx_not_interrupted(datetime(Start),winner(X),datetime(End)) :- Start \= bot,
      End \= eot, findall(Time,blawx_becomes(-winner(X),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).

      blawx_not_interrupted(datetime(Start),-winner(X),datetime(End)) :- Start \=
      bot, End \= eot, findall(Time,blawx_becomes(winner(X),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).

      blawx_not_interrupted(datetime(bot),winner(X),datetime(End)) :- End \= eot,
      findall(Time,blawx_becomes(-winner(X),datetime(Time)),Times),blawx_list_not_before(Times,End).

      blawx_not_interrupted(datetime(bot),-winner(X),datetime(End)) :- End \= eot,
      findall(Time,blawx_becomes(winner(X),datetime(Time)),Times),blawx_list_not_before(Times,End).

      blawx_not_interrupted(datetime(Start),winner(X),datetime(eot)) :- Start \= bot,
      findall(Time,blawx_becomes(-winner(X),datetime(Time)),Times),blawx_list_not_after(Times,Start).

      blawx_not_interrupted(datetime(Start),-winner(X),datetime(eot)) :- Start \=
      bot, findall(Time,blawx_becomes(winner(X),datetime(Time)),Times),blawx_list_not_after(Times,Start).

      blawx_not_interrupted(datetime(bot),winner(X),datetime(eot)) :- blawx_initially(winner(X)),
      blawx_ultimately(winner(X)), findall(Time,blawx_becomes(-winner(X),datetime(Time)),[]).

      blawx_not_interrupted(datetime(bot),-winner(X),datetime(eot)) :- blawx_initially(-winner(X)),
      blawx_ultimately(-winner(X)), findall(Time,blawx_becomes(winner(X),datetime(Time)),[]).

      blawx_as_of(winner(X),datetime(Time)) :- blawx_initially(winner(X)), BeforeT
      #< Time,blawx_not_interrupted(datetime(bot),winner(X),datetime(BeforeT)).

      blawx_as_of(winner(X),datetime(Time)) :- blawx_becomes(winner(X),datetime(BeforeT)),BeforeT
      #< Time,blawx_not_interrupted(datetime(BeforeT),winner(X),datetime(Time)).

      blawx_as_of(-winner(X),datetime(Time)) :- blawx_initially(-winner(X)), BeforeT
      #< Time,blawx_not_interrupted(datetime(bot),-winner(X),datetime(BeforeT)).

      blawx_as_of(-winner(X),datetime(Time)) :- blawx_becomes(-winner(X),datetime(BeforeT)),BeforeT
      #< Time,blawx_not_interrupted(datetime(BeforeT),-winner(X),datetime(Time)).

      blawx_during(datetime(Start),winner(X),datetime(End)) :- blawx_becomes(winner(X),datetime(Start)),
      blawx_becomes(-winner(X),datetime(End)), Start #< End, blawx_not_interrupted(datetime(Start),winner(X),datetime(End)).

      blawx_during(datetime(bot),winner(X),datetime(End)) :- blawx_initially(winner(X)),
      blawx_becomes(-winner(X),datetime(End)), blawx_not_interrupted(datetime(bot),winner(X),datetime(End)).

      blawx_during(datetime(Start),winner(X),datetime(eot)) :- blawx_ultimately(winner(X)),
      blawx_becomes(-winner(X),datetime(Start)), blawx_not_interrupted(datetime(Start),winner(X),datetime(eot)).

      blawx_during(datetime(bot),winner(X),datetime(eot)) :- blawx_initially(winner(X)),
      blawx_ultimately(winner(X)), blawx_becomes(-winner(X),datetime(Start)), blawx_not_interrupted(datetime(bot),winner(X),datetime(eot)).

      blawx_during(datetime(Start),-winner(X),datetime(End)) :- blawx_becomes(-winner(X),datetime(Start)),
      blawx_becomes(winner(X),datetime(End)), Start #< End, blawx_not_interrupted(datetime(Start),-winner(X),datetime(End)).

      blawx_during(datetime(bot),-winner(X),datetime(End)) :- blawx_initially(-winner(X)),
      blawx_becomes(winner(X),datetime(End)), blawx_not_interrupted(datetime(bot),-winner(X),datetime(End)).

      blawx_during(datetime(Start),-winner(X),datetime(eot)) :- blawx_ultimately(-winner(X)),
      blawx_becomes(winner(X),datetime(Start)), blawx_not_interrupted(datetime(Start),-winner(X),datetime(eot)).

      blawx_during(datetime(bot),-winner(X),datetime(eot)) :- blawx_initially(-winner(X)),
      blawx_ultimately(-winner(X)), blawx_becomes(-winner(X),datetime(Start)), blawx_not_interrupted(datetime(bot),-winner(X),datetime(eot)).


      blawx_category(sign).

      blawx_category_nlg(sign,"","is a sign").

      :- dynamic sign/1.

      #pred sign(X) :: ''@(X) is a sign''.

      #pred holds(user,sign,X) :: ''it is provided as a fact that @(X) is a sign''.

      #pred holds(user,-sign,X) :: ''it is provided as a fact that it is not the case
      that @(X) is a sign''.

      #pred holds(Z,sign,X) :: ''the conclusion in @(Z) that @(X) is a sign holds''.

      #pred holds(Z,-sign,X) :: ''the conclusion in @(Z) that it is not the case that
      @(X) is a sign holds''.

      #pred according_to(Z,sign,X) :: ''according to @(Z), @(X) is a sign''.

      #pred according_to(Z,-sign,X) :: ''according to @(Z), it is not the case that
      @(X) is a sign''.

      #pred blawx_defeated(Z,sign,X) :: ''the conclusion in @(Z) that @(X) is a sign
      is defeated''.

      #pred blawx_defeated(Z,-sign,X) :: ''the conclusion in @(Z) that it is not the
      case that @(X) is a sign is defeated''.

      #pred blawx_initially(sign(X)) :: ''that @(X) is a sign holds initially''.

      #pred blawx_initially(-sign(X)) :: ''that it is not the case that @(X) is a
      sign holds initially''.

      #pred blawx_ultimately(sign(X)) :: ''that @(X) is a sign holds ultimately''.

      #pred blawx_ultimately(-sign(X)) :: ''that it is not the case that @(X) is a
      sign holds ultimately''.

      #pred blawx_as_of(sign(X),T) :: ''that @(X) is a sign holds at @(T)''.

      #pred blawx_as_of(-sign(X),T) :: ''that it is not the case that @(X) is a sign
      holds at @(T)''.

      #pred blawx_during(T1,sign(X),T2) :: ''that @(X) is a sign held between @(T1)
      and @(T2)''.

      #pred blawx_during(T1,-sign(X),T2) :: ''that it is not the case that @(X) is
      a sign held between @(T1) and @(T2)''.

      #pred blawx_becomes(sign(X),T) :: ''that @(X) is a sign became true at @(T)''.

      #pred blawx_becomes(-sign(X),T) :: ''that it is not the case that @(X) is a
      sign became true at @(T)''.

      #pred blawx_not_interrupted(Start,sign(X),End) :: ''@(X) is a sign remained
      the case between @(Start) and @(End)''.

      #pred blawx_not_interrupted(Start,-sign(X),End) :: ''it is not the case that
      @(X) is a sign remained the case between @(Start) and @(End)''.

      blawx_not_interrupted(datetime(Start),sign(X),datetime(End)) :- Start \= bot,
      End \= eot, findall(Time,blawx_becomes(-sign(X),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).

      blawx_not_interrupted(datetime(Start),-sign(X),datetime(End)) :- Start \= bot,
      End \= eot, findall(Time,blawx_becomes(sign(X),datetime(Time)),Times),blawx_list_not_between(Times,Start,End).

      blawx_not_interrupted(datetime(bot),sign(X),datetime(End)) :- End \= eot, findall(Time,blawx_becomes(-sign(X),datetime(Time)),Times),blawx_list_not_before(Times,End).

      blawx_not_interrupted(datetime(bot),-sign(X),datetime(End)) :- End \= eot, findall(Time,blawx_becomes(sign(X),datetime(Time)),Times),blawx_list_not_before(Times,End).

      blawx_not_interrupted(datetime(Start),sign(X),datetime(eot)) :- Start \= bot,
      findall(Time,blawx_becomes(-sign(X),datetime(Time)),Times),blawx_list_not_after(Times,Start).

      blawx_not_interrupted(datetime(Start),-sign(X),datetime(eot)) :- Start \= bot,
      findall(Time,blawx_becomes(sign(X),datetime(Time)),Times),blawx_list_not_after(Times,Start).

      blawx_not_interrupted(datetime(bot),sign(X),datetime(eot)) :- blawx_initially(sign(X)),
      blawx_ultimately(sign(X)), findall(Time,blawx_becomes(-sign(X),datetime(Time)),[]).

      blawx_not_interrupted(datetime(bot),-sign(X),datetime(eot)) :- blawx_initially(-sign(X)),
      blawx_ultimately(-sign(X)), findall(Time,blawx_becomes(sign(X),datetime(Time)),[]).

      blawx_as_of(sign(X),datetime(Time)) :- blawx_initially(sign(X)), BeforeT #<
      Time,blawx_not_interrupted(datetime(bot),sign(X),datetime(BeforeT)).

      blawx_as_of(sign(X),datetime(Time)) :- blawx_becomes(sign(X),datetime(BeforeT)),BeforeT
      #< Time,blawx_not_interrupted(datetime(BeforeT),sign(X),datetime(Time)).

      blawx_as_of(-sign(X),datetime(Time)) :- blawx_initially(-sign(X)), BeforeT #<
      Time,blawx_not_interrupted(datetime(bot),-sign(X),datetime(BeforeT)).

      blawx_as_of(-sign(X),datetime(Time)) :- blawx_becomes(-sign(X),datetime(BeforeT)),BeforeT
      #< Time,blawx_not_interrupted(datetime(BeforeT),-sign(X),datetime(Time)).

      blawx_during(datetime(Start),sign(X),datetime(End)) :- blawx_becomes(sign(X),datetime(Start)),
      blawx_becomes(-sign(X),datetime(End)), Start #< End, blawx_not_interrupted(datetime(Start),sign(X),datetime(End)).

      blawx_during(datetime(bot),sign(X),datetime(End)) :- blawx_initially(sign(X)),
      blawx_becomes(-sign(X),datetime(End)), blawx_not_interrupted(datetime(bot),sign(X),datetime(End)).

      blawx_during(datetime(Start),sign(X),datetime(eot)) :- blawx_ultimately(sign(X)),
      blawx_becomes(-sign(X),datetime(Start)), blawx_not_interrupted(datetime(Start),sign(X),datetime(eot)).

      blawx_during(datetime(bot),sign(X),datetime(eot)) :- blawx_initially(sign(X)),
      blawx_ultimately(sign(X)), blawx_becomes(-sign(X),datetime(Start)), blawx_not_interrupted(datetime(bot),sign(X),datetime(eot)).

      blawx_during(datetime(Start),-sign(X),datetime(End)) :- blawx_becomes(-sign(X),datetime(Start)),
      blawx_becomes(sign(X),datetime(End)), Start #< End, blawx_not_interrupted(datetime(Start),-sign(X),datetime(End)).

      blawx_during(datetime(bot),-sign(X),datetime(End)) :- blawx_initially(-sign(X)),
      blawx_becomes(sign(X),datetime(End)), blawx_not_interrupted(datetime(bot),-sign(X),datetime(End)).

      blawx_during(datetime(Start),-sign(X),datetime(eot)) :- blawx_ultimately(-sign(X)),
      blawx_becomes(sign(X),datetime(Start)), blawx_not_interrupted(datetime(Start),-sign(X),datetime(eot)).

      blawx_during(datetime(bot),-sign(X),datetime(eot)) :- blawx_initially(-sign(X)),
      blawx_ultimately(-sign(X)), blawx_becomes(-sign(X),datetime(Start)), blawx_not_interrupted(datetime(bot),-sign(X),datetime(eot)).

      sign(rock).

      sign(paper).

      sign(scissor).'
